{
  "expo": {
    "name": "pipeline",
    "slug": "pipeline",
    "scheme": "pipeline",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.projectstudio.pipeline",
      "associatedDomains": ["applinks:pipeline.projectstudio.ai"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "ai.projectstudio.pipeline",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "pipeline.projectstudio.ai",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "444a55c7-c52b-4d5b-9cb9-ddd1bb7cde8c"
      }
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "pipeline",
          "organization": "projectstudio"
        }
      ],
      "expo-splash-screen",
      "expo-font",
      "expo-secure-store",
      "@sentry/react-native",
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
          "recordAudioAndroid": true
        }
      ]
    ],
    "assetBundlePatterns": ["**/*", "assets/pdfjs/*"]
  }
}
