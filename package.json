    "ios:go": "expo start --ios",
    "web": "expo start --web",
    "clean:node": "rm -rf node_modules package-lock.json && npm install",
    "clean:expo": "rm -rf $TMPDIR/metro-* $TMPDIR/react-* $TMPDIR/haste-map-* $TMPDIR/expo-* && npx expo start -c",
